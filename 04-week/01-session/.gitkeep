Las sentencias DML son un conjunto de instrucciones del lenguaje SQL que permiten manipular los datos almacenados en una base de datos.

Estas incluyen operaciones como:
- INSERT: para insertar datos
- SELECT: para consultar información
- DELETE: para eliminar datos

1- INSERT

 sintaxis básica de un comando INSERT en SQL

INSERT INTO [tabla] (columna1, columna2, columna3) VALUES (valor1, valor2, valor3);

SECURITY
-- ROLE
INSERT INTO security.role (id, name, description, created_by) VALUES
('11111111-1111-1111-1111-111111111111','Admin','Administrador','system'),
('22222222-2222-2222-2222-222222222222','User','Usuario','system'),
('33333333-3333-3333-3333-333333333333','Guest','Invitado','system');

-- USER
INSERT INTO security."user" (id, username, email, password, role_id, created_by) VALUES
('aaaaaaa1-1111-1111-1111-111111111111','juan','juan@gmail.com','123','11111111-1111-1111-1111-111111111111','system'),
('aaaaaaa2-2222-2222-2222-222222222222','ana','ana@gmail.com','123','22222222-2222-2222-2222-222222222222','system'),
('aaaaaaa3-3333-3333-3333-333333333333','carlos','carlos@gmail.com','123','33333333-3333-3333-3333-333333333333','system');

-- FORM
INSERT INTO security.form (id, name, route, created_by) VALUES
('f1111111-1111-1111-1111-111111111111','Login','/login','system'),
('f2222222-2222-2222-2222-222222222222','Dashboard','/dashboard','system'),
('f3333333-3333-3333-3333-333333333333','Settings','/settings','system');


INVENTORY
-- CATEGORY
INSERT INTO inventory.category (id, name, description, created_by) VALUES
('c1111111-1111-1111-1111-111111111111','Bebidas','Liquidos','system'),
('c2222222-2222-2222-2222-222222222222','Snacks','Comida','system'),
('c3333333-3333-3333-3333-333333333333','Aseo','Limpieza','system');

-- PRODUCT
INSERT INTO inventory.product (id, name, description, price, category_id, created_by) VALUES
('p1111111-1111-1111-1111-111111111111','Coca-Cola','Gaseosa',3000,'c1111111-1111-1111-1111-111111111111','system'),
('p2222222-2222-2222-2222-222222222222','Papas','Snack',2000,'c2222222-2222-2222-2222-222222222222','system'),
('p3333333-3333-3333-3333-333333333333','Jabon','Limpieza',2500,'c3333333-3333-3333-3333-333333333333','system');

-- INVENTORY
INSERT INTO inventory.inventory (id, product_id, quantity, created_by) VALUES
('i1111111-1111-1111-1111-111111111111','p1111111-1111-1111-1111-111111111111',50,'system'),
('i2222222-2222-2222-2222-222222222222','p2222222-2222-2222-2222-222222222222',30,'system'),
('i3333333-3333-3333-3333-333333333333','p3333333-3333-3333-3333-333333333333',20,'system');


BILL
-- BILL
INSERT INTO bill.bill (id, user_id, total, created_by) VALUES
('b1111111-1111-1111-1111-111111111111','aaaaaaa1-1111-1111-1111-111111111111',5000,'system'),
('b2222222-2222-2222-2222-222222222222','aaaaaaa2-2222-2222-2222-222222222222',4000,'system'),
('b3333333-3333-3333-3333-333333333333','aaaaaaa3-3333-3333-3333-333333333333',3000,'system');

-- BILL ITEM
INSERT INTO bill.bill_item (id, bill_id, product_id, quantity, unit_price, total, created_by) VALUES
('bi111111-1111-1111-1111-111111111111','b1111111-1111-1111-1111-111111111111','p1111111-1111-1111-1111-111111111111',1,3000,3000,'system'),
('bi222222-2222-2222-2222-222222222222','b2222222-2222-2222-2222-222222222222','p2222222-2222-2222-2222-222222222222',2,2000,4000,'system'),
('bi333333-3333-3333-3333-333333333333','b3333333-3333-3333-3333-333333333333','p3333333-3333-3333-3333-333333333333',1,2500,2500,'system');


