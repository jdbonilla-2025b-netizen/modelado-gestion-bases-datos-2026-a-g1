SELECT
-- ROLE
SELECT * FROM security.role;
SELECT * FROM security.role WHERE state = 'ACTIVE';
SELECT * FROM security.role WHERE name = 'Admin';

-- USER
SELECT * FROM security."user";
SELECT * FROM security."user" WHERE username = 'juan';
SELECT * FROM security."user" WHERE state = 'ACTIVE';

-- FORM
SELECT * FROM security.form;
SELECT * FROM security.form WHERE name = 'Login';
SELECT * FROM security.form WHERE state = 'ACTIVE';

-- CATEGORY
SELECT * FROM inventory.category;
SELECT * FROM inventory.category WHERE name = 'Bebidas';
SELECT * FROM inventory.category WHERE state = 'ACTIVE';

-- PRODUCT
SELECT * FROM inventory.product;
SELECT * FROM inventory.product WHERE price > 2000;
SELECT * FROM inventory.product WHERE state = 'ACTIVE';

-- INVENTORY
SELECT * FROM inventory.inventory;
SELECT * FROM inventory.inventory WHERE quantity > 25;
SELECT * FROM inventory.inventory WHERE state = 'ACTIVE';

-- BILL
SELECT * FROM bill.bill;
SELECT * FROM bill.bill WHERE total > 3000;
SELECT * FROM bill.bill WHERE state = 'ACTIVE';

-- BILL ITEM
SELECT * FROM bill.bill_item;
SELECT * FROM bill.bill_item WHERE quantity > 1;
SELECT * FROM bill.bill_item WHERE state = 'ACTIVE';



DELETE
-- BILL ITEM
DELETE FROM bill.bill_item WHERE quantity = 1;
DELETE FROM bill.bill_item WHERE quantity = 2;
DELETE FROM bill.bill_item WHERE total = 3000;

-- BILL
DELETE FROM bill.bill WHERE total = 3000;
DELETE FROM bill.bill WHERE total = 4000;
DELETE FROM bill.bill WHERE total = 5000;

-- INVENTORY
DELETE FROM inventory.inventory WHERE quantity = 20;
DELETE FROM inventory.inventory WHERE quantity = 30;
DELETE FROM inventory.inventory WHERE quantity = 50;

-- PRODUCT
DELETE FROM inventory.product WHERE name = 'Jabon';
DELETE FROM inventory.product WHERE name = 'Papas';
DELETE FROM inventory.product WHERE name = 'Coca-Cola';

-- CATEGORY
DELETE FROM inventory.category WHERE name = 'Aseo';
DELETE FROM inventory.category WHERE name = 'Snacks';
DELETE FROM inventory.category WHERE name = 'Bebidas';

-- USER
DELETE FROM security."user" WHERE username = 'carlos';
DELETE FROM security."user" WHERE username = 'ana';
DELETE FROM security."user" WHERE username = 'juan';

-- ROLE
DELETE FROM security.role WHERE name = 'Guest';
DELETE FROM security.role WHERE name = 'User';
DELETE FROM security.role WHERE name = 'Admin';